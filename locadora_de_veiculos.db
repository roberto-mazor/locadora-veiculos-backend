-- 1. Criação da tabela de Veículos
CREATE TABLE IF NOT EXISTS veiculos (
    id SERIAL PRIMARY KEY,
    modelo VARCHAR(100) NOT NULL,
    marca VARCHAR(50) NOT NULL,
    placa VARCHAR(10) NOT NULL UNIQUE,
    categoria VARCHAR(50) NOT NULL,
    valor_diaria DECIMAL(10, 2) NOT NULL,
    status VARCHAR(20) DEFAULT 'Disponível'
);

-- 2. Criação da tabela de Usuários (Nível 2 - US5 e US6)
CREATE TABLE IF NOT EXISTS usuarios (
    id SERIAL PRIMARY KEY,
    login VARCHAR(150) NOT NULL UNIQUE,
    senha VARCHAR(255) NOT NULL, -- Armazena Hash Bcrypt
    nivel_acesso VARCHAR(20) DEFAULT 'Operador'
);

-- 3. Criação da tabela de Agendamentos (Com Chave Estrangeira)
CREATE TABLE IF NOT EXISTS agendamentos (
    id SERIAL PRIMARY KEY,
    nome_cliente VARCHAR(150) NOT NULL,
    email_cliente VARCHAR(150) NOT NULL,
    categoria_interesse VARCHAR(50),
    veiculo_id INTEGER REFERENCES veiculos(id) ON DELETE SET NULL,
    data_reserva TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    quantidade_diarias INTEGER DEFAULT 1,
    valor_total DECIMAL(10, 2) DEFAULT 0.00
);

